  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ezpaarse-project/ezcounter.git"
  },
  "type": "module",
  "exports": {
    "./schemas": "./src/lib/ajv.ts",
    "./schemas/*": "./dist/*.ts"
  },
  "scripts": {
    "build:schemas": "tsx schemas/build.ts",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "type-check": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint --fix",
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "package.json": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": "^20 || ^22 || ^24"
  }
