{
  "$schema": "https://v2-9-12.turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "fmt": {
      "dependsOn": ["^fmt"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
