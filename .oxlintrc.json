{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["./node_modules/@ezpaarse-project/oxlint-config/ts.jsonc"],

  "plugins": ["node"],

  "rules": {
    // Project is using Node
    "no-nodejs-modules": "off",
    // Project is using ESM
    "import/extensions": ["error", "never"],
    "import/no-commonjs": "error",
    "import/unambiguous": "error",
    "unicorn/prefer-module": "error",
    "typescript/no-require-imports": "error",
    "typescript/no-var-requires": "error",
    // Project is using oxfmt sort feature
    "sort-imports": [
      "warn",
      { "ignoreDeclarationSort": true, "allowSeparatedGroups": true }
    ]
  },

  "overrides": [
    {
      "files": ["*.test.ts"],

      "plugins": ["vitest"],

      "rules": {
        // Project is using vitest
        "vitest/prefer-to-be-truthy": "off",
        "vitest/prefer-to-be-falsy": "off",
        "vitest/prefer-called-times": "off",
        "vitest/no-importing-vitest-globals": "off",
        // Tests files can have a lot of tests, and it's more readable to have only 1 test file per TS file
        "max-lines": "off",
        "max-lines-per-function": "off",
        // Tests can check for constants
        "no-magic-numbers": "off"
      }
    },
    {
      "files": ["**/__mocks__/*.ts"],

      "plugins": ["vitest"],

      "rules": {
        // Project is using vitest
        "vitest/no-importing-vitest-globals": "off",
        // Allow namespaces to ease typing of mock functions
        "import/no-namespace": "off"
      }
    }
  ]
}
